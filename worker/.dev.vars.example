# Copy this file to .dev.vars and fill in your real keys.
# .dev.vars is git-ignored; it is only used by `wrangler dev` locally.
# For production, add each value as a Wrangler secret:
#   wrangler secret put ANTHROPIC_API_KEY   (then paste the value)

ANTHROPIC_API_KEY=sk-ant-...
CARSXE_API_KEY=...
AZURE_SPEECH_KEY=...
AZURE_SPEECH_REGION=eastus
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID_EN=...
ELEVENLABS_VOICE_ID_HY=...
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...
PRODUCTION_ORIGIN=https://your-production-domain.com
